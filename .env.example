# Copy to .env — backend must be running (see ../backend)
#
# Physical phone (Expo Go): use your PC's Wi‑Fi IP, OR leave as localhost and the app
# will auto-use the same IP as the Expo QR code (e.g. 192.168.x.x).
#
# Android emulator: localhost is auto-rewritten to http://10.0.2.2:3001
# iOS simulator: http://localhost:3001 works
#
EXPO_PUBLIC_API_URL=http://localhost:3001
